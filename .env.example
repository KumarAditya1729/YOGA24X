# ==============================================================================
# Yoga24X AI Engineering OS — Global Environment Template (.env.example)
# DO NOT COMMIT ACTUAL SECRETS TO THIS FILE. COPY TO .env AND FILL IN VALUES.
# ==============================================================================

# General Application Environment
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# PostgreSQL Database (Prisma ORM)
DATABASE_URL="postgresql://postgres:root@localhost:5432/yoga24x_dev?schema=public"
DB_MAX_CONNECTIONS=20

# Redis Cache & Pub/Sub
REDIS_URL="redis://localhost:6379/0"
REDIS_PASSWORD=

# Authentication & JWT Secrets
JWT_ACCESS_SECRET="YOUR_DEV_ACCESS_SECRET_STRING_HERE"
JWT_REFRESH_SECRET="YOUR_DEV_REFRESH_SECRET_STRING_HERE"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Google OAuth 2.0
GOOGLE_CLIENT_ID="mock-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="mock-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# OTP & SMS Gateway (Twilio / Firebase / MSG91)
SMS_GATEWAY_API_KEY="mock_sms_gateway_api_key"
SMS_SENDER_ID="YOGA24"

# AWS S3 Compatible Storage (CloudFront CDN)
S3_ENDPOINT="http://localhost:4566"
S3_REGION="us-east-1"
S3_BUCKET_NAME="yoga24x-dev-media"
S3_ACCESS_KEY_ID="test"
S3_SECRET_ACCESS_KEY="test"
CDN_DOMAIN="https://cdn.dev.yoga24x.com"

# Razorpay Payment Gateway
RAZORPAY_KEY_ID="rzp_test_mock_key_id_123456"
RAZORPAY_KEY_SECRET="rzp_test_mock_secret_key_123456"
RAZORPAY_WEBHOOK_SECRET="rzp_test_mock_webhook_secret"

# Firebase Cloud Messaging (FCM Push Notifications)
FCM_PROJECT_ID="yoga24x-dev"
FCM_PRIVATE_KEY="YOUR_FCM_PRIVATE_KEY"
FCM_CLIENT_EMAIL="firebase-adminsdk@your-project-id.iam.gserviceaccount.com"

# AI Pose Tracking & Telemetry Engine
AI_TELEMETRY_WS_PORT=3002
ENABLE_AI_V2_POSE_MODEL=true
MIN_POSE_ACCURACY_THRESHOLD=0.75

# Observability & Monitoring
SENTRY_DSN="https://mock@sentry.io/123456"
LOG_LEVEL=debug
