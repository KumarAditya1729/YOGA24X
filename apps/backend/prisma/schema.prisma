}

// ── Verification (KYC Workflow) ────────────────────────────────────────────────

model TeacherVerification {
  id                   String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String                    @unique @map("user_id") @db.Uuid
  status               TeacherVerificationStatus @default(PENDING)
  identityVerified     Boolean                   @default(false) @map("identity_verified")
  certificateVerified  Boolean                   @default(false) @map("certificate_verified")
  manualReviewRequired Boolean                   @default(false) @map("manual_review_required")
  aiFraudScore         Decimal?                  @map("ai_fraud_score") @db.Decimal(5, 4)
  aiFraudFlagged       Boolean                   @default(false) @map("ai_fraud_flagged")
  aiFraudReason        String?                   @map("ai_fraud_reason") @db.Text
  reviewedBy           String?                   @map("reviewed_by") @db.Uuid
  reviewedAt           DateTime?                 @map("reviewed_at") @db.Timestamptz(6)
  reviewNotes          String?                   @map("review_notes") @db.Text
  submissionCount      Int                       @default(1) @map("submission_count")
  lastSubmittedAt      DateTime                  @default(now()) @map("last_submitted_at") @db.Timestamptz(6)
  approvedAt           DateTime?                 @map("approved_at") @db.Timestamptz(6)
  rejectedAt           DateTime?                 @map("rejected_at") @db.Timestamptz(6)
  rejectionReason      String?                   @map("rejection_reason") @db.Text
  createdAt            DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacher   TeacherProfile                @relation(fields: [userId], references: [userId], onDelete: Cascade)
  documents TeacherVerificationDocument[]

  @@index([status, aiFraudFlagged], name: "idx_teacher_verif_status_fraud")
  @@map("teacher_verifications")
}

model TeacherVerificationDocument {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  verificationId String    @map("verification_id") @db.Uuid
  documentType   String    @map("document_type") @db.VarChar(100)
  documentUrl    String    @map("document_url") @db.Text
  fileHash       String?   @map("file_hash") @db.VarChar(255)
  fileSizeBytes  Int?      @map("file_size_bytes")
  mimeType       String?   @map("mime_type") @db.VarChar(100)
  isVerified     Boolean   @default(false) @map("is_verified")
  verifiedAt     DateTime? @map("verified_at") @db.Timestamptz(6)
  uploadedAt     DateTime  @default(now()) @map("uploaded_at") @db.Timestamptz(6)

  verification TeacherVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId], name: "idx_teacher_verif_doc_verif_id")
  @@map("teacher_verification_documents")
}

// ── Professional Statistics ────────────────────────────────────────────────────

