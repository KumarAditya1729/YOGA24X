model TeacherReviewReply {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewId  String   @unique @map("review_id") @db.Uuid
  replyText String   @map("reply_text") @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  review TeacherReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("teacher_review_replies")
}

// ==============================================================================
// 18. TEACHER OPERATIONS PLATFORM — Prompt 6.2
//     Availability, Scheduling, Bookings, Sessions, Pricing, Roster, Wallet
// ==============================================================================

// ── Enums ──────────────────────────────────────────────────────────────────────

enum SessionFormat {
  PRIVATE
  GROUP
  CORPORATE
  STUDIO
  HOME_VISIT
  ONLINE
  HYBRID
  RETREAT
  WORKSHOP
  TEACHER_TRAINING

  @@map("session_format_enum")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED

  @@map("payout_status_enum")
}

// ── Rules & Preferences ────────────────────────────────────────────────────────

model TeacherBookingRule {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String   @unique @map("user_id") @db.Uuid
  advanceBookingDays      Int      @default(30) @map("advance_booking_days")
  minimumNoticeHours      Int      @default(24) @map("minimum_notice_hours")
  cancellationWindowHours Int      @default(24) @map("cancellation_window_hours")
  reschedulePolicyHours   Int      @default(12) @map("reschedule_policy_hours")
  bufferTimeMinutes       Int      @default(15) @map("buffer_time_minutes")
  maxDailySessions        Int?     @map("max_daily_sessions")
  maxWeeklyHours          Int?     @map("max_weekly_hours")
  lateArrivalGraceMins    Int      @default(10) @map("late_arrival_grace_mins")
  preventOverbooking      Boolean  @default(true) @map("prevent_overbooking")
  allowWaitlist           Boolean  @default(true) @map("allow_waitlist")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacher TeacherProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("teacher_booking_rules")
}

model TeacherHoliday {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  reason      String?  @db.VarChar(255)
  isEmergency Boolean  @default(false) @map("is_emergency")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  teacher TeacherProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, startDate, endDate], name: "idx_teacher_holidays_user_date")
  @@map("teacher_holidays")
}

// ── Session Types & Pricing ────────────────────────────────────────────────────

model TeacherSessionType {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  title           String        @db.VarChar(255)
  description     String?       @db.Text
  format          SessionFormat
  durationMinutes Int           @map("duration_minutes")
  basePriceCents  Int           @map("base_price_cents")
  currency        String        @default("USD") @db.VarChar(3)
  maxParticipants Int           @default(1) @map("max_participants")
  isActive        Boolean       @default(true) @map("is_active")
  isOnline        Boolean       @default(true) @map("is_online")
  taxRatePercent  Decimal       @default(0.00) @map("tax_rate_percent") @db.Decimal(5, 2)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacher  TeacherProfile   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  sessions TeacherSession[]

  @@index([userId, isActive], name: "idx_teacher_sess_type_user_act")
  @@map("teacher_session_types")
}

model TeacherPricingRule {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  ruleName          String          @db.VarChar(255)
  markupPercent     Decimal?        @map("markup_percent") @db.Decimal(5, 2)
  discountPercent   Decimal?        @map("discount_percent") @db.Decimal(5, 2)
  isWeekend         Boolean         @default(false) @map("is_weekend")
  isPeakHour        Boolean         @default(false) @map("is_peak_hour")
  applicableFormats SessionFormat[] @map("applicable_formats")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  teacher TeacherProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("teacher_pricing_rules")
}

// ── Scheduling & Bookings ──────────────────────────────────────────────────────

model TeacherSession {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherUserId   String   @map("teacher_user_id") @db.Uuid
  sessionTypeId   String   @map("session_type_id") @db.Uuid
  title           String   @db.VarChar(255)
  startTime       DateTime @map("start_time") @db.Timestamptz(6)
  endTime         DateTime @map("end_time") @db.Timestamptz(6)
  maxParticipants Int      @default(1) @map("max_participants")
  currentBookings Int      @default(0) @map("current_bookings")
  status          String   @default("SCHEDULED") @db.VarChar(30)
  meetingUrl      String?  @map("meeting_url") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacher         TeacherProfile     @relation(fields: [teacherUserId], references: [userId], onDelete: Cascade)
  sessionType     TeacherSessionType @relation(fields: [sessionTypeId], references: [id], onDelete: Restrict)
  bookings        TeacherBooking[]
  waitlistEntries WaitlistEntry[]

  @@index([teacherUserId, startTime, endTime], name: "idx_teacher_session_time")
  @@index([status], name: "idx_teacher_session_status")
  @@map("teacher_sessions")
}

model TeacherBooking {
  id                       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId                String        @map("session_id") @db.Uuid
  studentUserId            String        @map("student_user_id") @db.Uuid
  status                   BookingStatus @default(CONFIRMED)
  paymentTransactionId     String?       @map("payment_transaction_id") @db.Uuid
  bookedAt                 DateTime      @default(now()) @map("booked_at") @db.Timestamptz(6)
  cancelledAt              DateTime?     @map("cancelled_at") @db.Timestamptz(6)
  rescheduledFromId        String?       @map("rescheduled_from_id") @db.Uuid
  cancellationReason       String?       @map("cancellation_reason") @db.VarChar(500)
  cancellationPenaltyCents Int?          @default(0) @map("cancellation_penalty_cents")
  expiresAt                DateTime?     @map("expires_at") @db.Timestamptz(6)
  bookingNotes             String?       @map("booking_notes") @db.Text
  correlationId            String?       @map("correlation_id") @db.VarChar(255)

  session         TeacherSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student         User                      @relation(fields: [studentUserId], references: [id], onDelete: Cascade)
  attendance      TeacherSessionAttendance?
  rescheduledFrom TeacherBooking?           @relation("RescheduleChain", fields: [rescheduledFromId], references: [id])
  rescheduledTo   TeacherBooking[]          @relation("RescheduleChain")
  waitlistEntry   WaitlistEntry?
  calendarSyncs   CalendarEventSync[]

  @@index([sessionId, status], name: "idx_teacher_booking_sess_stat")
  @@index([studentUserId], name: "idx_teacher_booking_student")
  @@map("teacher_bookings")
}

model TeacherSessionAttendance {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId      String    @unique @map("booking_id") @db.Uuid
  studentUserId  String    @map("student_user_id") @db.Uuid
  attended       Boolean   @default(false)
  joinedAt       DateTime? @map("joined_at") @db.Timestamptz(6)
  leftAt         DateTime? @map("left_at") @db.Timestamptz(6)
  notes          String?   @db.Text
  checkInMethod  String?   @default("MANUAL") @map("check_in_method") @db.VarChar(20)
  checkInToken   String?   @map("check_in_token") @db.VarChar(512)
  geoLat         Decimal?  @map("geo_lat") @db.Decimal(10, 7)
  geoLng         Decimal?  @map("geo_lng") @db.Decimal(10, 7)
  deviceIp       String?   @map("device_ip") @db.VarChar(45)
  isLate         Boolean   @default(false) @map("is_late")
  markedByUserId String?   @map("marked_by_user_id") @db.Uuid

  booking TeacherBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  student User           @relation(fields: [studentUserId], references: [id], onDelete: Cascade)

  @@map("teacher_session_attendance")
}

// ── Student Management (Roster) ────────────────────────────────────────────────

model TeacherStudentRoster {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherUserId  String    @map("teacher_user_id") @db.Uuid
  studentUserId  String    @map("student_user_id") @db.Uuid
