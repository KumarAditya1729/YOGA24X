// ==============================================================================
// Yoga24X AI Engineering OS — Master Production Prisma Schema (schema.prisma)
// Supported Engine: PostgreSQL 16+ (with pgvector, pg_trgm, btree_gist extensions)
// Designed for 10M+ Users, 100K+ Teachers, 1M+ Courses, 10M+ Bookings
// ==============================================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "views", "nativeDistinct"]
}

// ==============================================================================
// 1. EXTENSIONS & ENUMS
// ==============================================================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DELETED

  @@map("user_status_enum")
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY

  @@map("gender_enum")
}

enum DoshaType {
  VATA
  PITTA
  KAPHA
  VATA_PITTA
  PITTA_KAPHA
  VATA_KAPHA
  TRIDOSHIC

  @@map("dosha_type_enum")
}

enum CourseVisibility {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  AUDIO
  ARTICLE
  PDF
  PRESENTATION
  GALLERY
  DOWNLOAD
  EXTERNAL
  ASSIGNMENT
  REFLECTION
}

enum LearningEventType {
  WORKSHOP
  RETREAT
  LIVE_CLASS
  TRAINING
  CORPORATE
}

enum WaitlistStatus {
  PENDING
  PROMOTED
  EXPIRED
  DECLINED
}

enum CheckInMethod {
  QR
  OTP
  GEO
  MANUAL
  REPLAY
}

enum CalendarProvider {
  GOOGLE
  APPLE
  ICS
}

enum CancellationPenaltyType {
  NONE
  FIXED
  PERCENTAGE
}

enum PublicationType {
  BLOG
  ARTICLE
  PODCAST
  SHORT_VIDEO
  RESOURCE
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS

  @@map("course_level_enum")
}

enum BookingStatus {
  DRAFT
  PENDING
  CONFIRMED
  RESCHEDULED
  CHECKED_IN
  STARTED
  COMPLETED
  CANCELLED
  EXPIRED
  NO_SHOW
  REFUNDED
  AUTO_CLOSED

  @@map("booking_status_enum")
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED

  @@map("payment_status_enum")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED

  @@map("order_status_enum")
}

enum OtpPurpose {
  LOGIN
  PASSWORD_RESET
  PHONE_VERIFY
  TWO_FACTOR

  @@map("otp_purpose_enum")
}

enum IdentityProvider {
  EMAIL
  PHONE
  GOOGLE
  APPLE

  @@map("identity_provider_enum")
}

enum LoginStatus {
  SUCCESS
  FAILED
  BLOCKED
  SUSPICIOUS

  @@map("login_status_enum")
}

enum AchievementType {
  BADGE
  MILESTONE
  LEVEL_UP
  STREAK

  @@map("achievement_type_enum")
}

enum RelationshipType {
  PARENT
  GUARDIAN
  SIBLING
  SPOUSE
  FRIEND
  OTHER

  @@map("relationship_type_enum")
}

enum GroupType {
  PUBLIC
  PRIVATE
  TEACHER
  STUDIO
  CORPORATE
  CHALLENGE

  @@map("group_type_enum")
}

enum GroupRole {
  ADMIN
  MODERATOR
  MEMBER

  @@map("group_role_enum")
}

enum ChallengeType {
  SEVEN_DAY
  TWENTY_ONE_DAY
  THIRTY_DAY
  CUSTOM

  @@map("challenge_type_enum")
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE
  OTHER

  @@map("report_reason_enum")
}

enum ChatType {
  DIRECT
  GROUP
  BROADCAST

  @@map("chat_type_enum")
}

// ── Commerce Enums (Prompt 10) ────────────────────────────────────────────────

enum MembershipType {
  MONTHLY
  QUARTERLY
  YEARLY
  LIFETIME
  CORPORATE
  STUDIO
  FAMILY

  @@map("membership_type_enum")
}

enum MembershipStatus {
  ACTIVE
  FROZEN
  EXPIRED
  CANCELLED
  PENDING

  @@map("membership_status_enum")
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_TRIAL
  GIFT_CARD
  REFERRAL
  BULK
  CORPORATE
  FESTIVAL

  @@map("coupon_type_enum")
}

enum RefundStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  FAILED

  @@map("refund_status_enum")
}

enum RefundReason {
  DUPLICATE_PAYMENT
  CLASS_CANCELLED
  POOR_EXPERIENCE
  MEDICAL
  TECHNICAL_ISSUE
  OTHER

  @@map("refund_reason_enum")
}

enum WalletType {
  STUDENT
  TEACHER
  CORPORATE
  REFUND
  BONUS
  REWARD

  @@map("wallet_type_enum")
}

enum RevenueShareType {
  TEACHER
  STUDIO
  AFFILIATE
  PARTNER
  PLATFORM

  @@map("revenue_share_type_enum")
}

enum InvoiceType {
  INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
  RECEIPT
  REFUND_RECEIPT

  @@map("invoice_type_enum")
}

enum PricingRuleType {
  REGIONAL
  FESTIVAL
  BULK
  CORPORATE
  REFERRAL
  EARLY_BIRD
  DYNAMIC

  @@map("pricing_rule_type_enum")
}

enum SettlementStatus {
  PENDING
  PROCESSING
  SETTLED
  FAILED

  @@map("settlement_status_enum")
}

enum GiftCardStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  REVOKED

  @@map("gift_card_status_enum")
}

// ==============================================================================
// 2. IDENTITY, RBAC & PERMISSIONS (Tasks 8, 9, 18, 31-37)
// ==============================================================================

model User {
  aiConversations     AiConversation[] @relation("UserConversations")
  aiSafetyAudits      AiSafetyAuditLog[] @relation("UserSafetyAudits")

  id                          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                       String     @unique @db.VarChar(255)
  phoneNumber                 String?    @unique @map("phone_number") @db.VarChar(20)
  passwordHash                String?    @map("password_hash") @db.VarChar(255)
  firstName                   String     @map("first_name") @db.VarChar(100)
  lastName                    String     @map("last_name") @db.VarChar(100)
  avatarUrl                   String?    @map("avatar_url") @db.Text
  status                      UserStatus @default(ACTIVE)
  isEmailVerified             Boolean    @default(false) @map("is_email_verified")
  isPhoneVerified             Boolean    @default(false) @map("is_phone_verified")
  twoFactorEnabled            Boolean    @default(false) @map("two_factor_enabled")
  twoFactorSecret             String?    @map("two_factor_secret") @db.VarChar(255)
  tenantId                    String?    @map("tenant_id") @db.Uuid
  profileCompletionPercentage Int        @default(0) @map("profile_completion_percentage")
  isDeleted                   Boolean    @default(false) @map("is_deleted")
  deletedAt                   DateTime?  @map("deleted_at") @db.Timestamptz(6)
  deletionScheduledAt         DateTime?  @map("deletion_scheduled_at") @db.Timestamptz(6)
  suspendedAt                 DateTime?  @map("suspended_at") @db.Timestamptz(6)
  suspensionReason            String?    @map("suspension_reason") @db.Text
  createdAt                   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  identities               UserIdentity[]
  trustedDevices           TrustedDevice[]
  loginHistory             LoginHistory[]
  userRoles                UserRole[]
  studentProfile           StudentProfile?
  instructorProfile        InstructorProfile?
  doctorProfile            DoctorProfile?
  nutritionistProfile      NutritionistProfile?
  studioProfile            StudioProfile?
  corporateProfile         CorporateProfile?
  adminProfile             AdminProfile?
  superAdminProfile        SuperAdminProfile?
  sessions                 UserSession[]
  devices                  UserDevice[]
  deviceHistory            DeviceHistory[]
  refreshTokens            RefreshToken[]
  wallet                   Wallet?
  bookings                 Booking[]
  courseEnrollments        CourseEnrollment[]
  certificates             UserCertificate[]
  subscriptions            UserSubscription[]
  paymentTransactions      PaymentTransaction[]
  orders                   Order[]
  communityPosts           CommunityPost[]
  postLikes                PostLike[]
  postComments             PostComment[]
  followers                UserFollower[]              @relation("UserFollowers")
  following                UserFollower[]              @relation("UserFollowing")
  
  // Social & Community Additions
  groupMemberships         GroupMember[]
  challengeParticipations  ChallengeParticipant[]
  chatMessages             ChatMessage[]
  chatParticipations       ChatParticipant[]
  messageReadReceipts      MessageReadReceipt[]
  postBookmarks            PostBookmark[]
  reportedContent          ReportedContent[]           @relation("Reporter")
  blockedUsers             BlockedUser[]               @relation("Blocker")
  blockedBy                BlockedUser[]               @relation("BlockedUser")
  leaderboardEntries       LeaderboardEntry[]
  aiCoachSessions          AiCoachSession[]
  userEmbedding            UserEmbedding?
  auditLogs                AuditLog[]                  @relation("AuditActor")
  notifications            Notification[]
  notificationPref         UserNotificationPreference?
  userSettings             UserSettings?
  userConsents             UserConsent[]
  dataExportRequests       DataExportRequest[]
  accountDeletionRequests  AccountDeletionRequest[]
  profileMedia             ProfileMedia[]
  verificationRequests     VerificationRequest[]
  organizationMembers      OrganizationMember[]
  ownedOrganizations       Organization[]              @relation("OrganizationOwner")
  createdTeams             OrganizationTeam[]          @relation("TeamLead")
  managedBranches          OrganizationBranch[]        @relation("BranchManager")
  healthProfile            HealthProfile?
  wellnessAssessments      WellnessAssessment[]
  yogaAssessment           YogaAssessment?
  nutritionProfile         NutritionProfile?
  meditationProfile        MeditationProfile?
  aiPersonalization        AiPersonalizationProfile?
  wellnessTimelineLogs     WellnessTimelineLog[]
  userGoals                UserGoal[]
  medicalSafetyFlags       MedicalSafetyFlag[]
  permissionOverrides      UserPermissionOverride[]    @relation("UserPermOverrides")
  teacherProfile           TeacherProfile?
  TeacherBooking           TeacherBooking[]
  TeacherSessionAttendance TeacherSessionAttendance[]
  TeacherStudentRoster     TeacherStudentRoster[]
  EventRegistration        EventRegistration[]
  LearningBookmark         LearningBookmark[]
  LearningNote             LearningNote[]
  LearningHighlight        LearningHighlight[]
  WatchHistory             WatchHistory[]
  WaitlistEntry            WaitlistEntry[]
  CalendarSyncProfile      CalendarSyncProfile[]
  GuardianProfile          GuardianProfile?            @relation("StudentGuardian")
  Guardianships            GuardianProfile[]           @relation("GuardianToStudent")
  EmergencyContacts        EmergencyContact[]
  MedicalVisibilityControl MedicalVisibilityControl?
  StudentAchievements      StudentAchievement[]
  StudentPreferences       StudentPreference?
  StudentAnalyticsSnapshot StudentAnalyticsSnapshot[]

  // Commerce Platform Additions (Prompt 10)
  memberships              Membership[]
  couponRedemptions        CouponRedemption[]
  giftCardsIssued          GiftCard[]                  @relation("GiftCardIssuedTo")
  giftCardsPurchased       GiftCard[]                  @relation("GiftCardPurchasedBy")
  giftCardRedemptions      GiftCardRedemption[]
  refunds                  Refund[]
  refundsApproved          Refund[]                    @relation("RefundApprover")
  revenueShares            RevenueShare[]              @relation("RevenueShareRecipient")
  settlementBatches        SettlementBatch[]           @relation("SettlementRecipient")

  // Admin Platform Additions (Prompt 12)
  cmsArticles              CmsArticle[]
  supportTicketsCreated    SupportTicket[]             @relation("TicketCreator")
  supportTicketsAssigned   SupportTicket[]             @relation("TicketAssignee")
  ticketComments           TicketComment[]

  @@index([email], name: "idx_users_email")
  @@index([phoneNumber], name: "idx_users_phone")
  @@index([status, tenantId], name: "idx_users_status_tenant")
  @@map("users")
}

model Role {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @unique @db.VarChar(50)
  description  String?  @db.Text
  isSystemRole Boolean  @default(true) @map("is_system_role")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module      String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@unique([module, action], name: "uq_permissions_module_action")
  @@map("permissions")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  assignedAt   DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedBy String?  @map("assigned_by") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ==============================================================================
// 3. SECURITY, SESSIONS, TOKENS & DEVICES (Tasks 31-37)
// ==============================================================================

model UserSession {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  deviceId     String?  @map("device_id") @db.Uuid
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime @default(now()) @map("last_active_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  device UserDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId, isActive], name: "idx_sessions_user_active")
  @@map("user_sessions")
}

model UserDevice {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  fcmToken          String?   @unique @map("fcm_token") @db.Text
  deviceType        String    @map("device_type") @db.VarChar(50)
  osVersion         String?   @map("os_version") @db.VarChar(50)
  appVersion        String?   @map("app_version") @db.VarChar(50)
  lastIp            String?   @map("last_ip") @db.VarChar(45)
  deviceNickname    String?   @map("device_nickname") @db.VarChar(100)
  deviceFingerprint String?   @map("device_fingerprint") @db.VarChar(255)
  lastActiveAt      DateTime? @map("last_active_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions UserSession[]

  @@index([userId], name: "idx_devices_user")
  @@map("user_devices")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  familyId  String   @map("family_id") @db.Uuid
  isRevoked Boolean  @default(false) @map("is_revoked")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tokenHash], name: "idx_refresh_user_hash")
  @@index([expiresAt], name: "idx_refresh_expiry")
  @@map("refresh_tokens")
}

model OtpVerification {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier  String     @db.VarChar(255)
  otpHash     String     @map("otp_hash") @db.VarChar(255)
  purpose     OtpPurpose
  attempts    Int        @default(0)
  maxAttempts Int        @default(3) @map("max_attempts")
  isUsed      Boolean    @default(false) @map("is_used")
  expiresAt   DateTime   @map("expires_at") @db.Timestamptz(6)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([identifier, purpose], name: "idx_otp_identifier_purpose")
  @@map("otp_verifications")
}

model SecurityBlockedIp {
  ipAddress String    @id @map("ip_address") @db.VarChar(45)
  reason    String    @db.VarChar(255)
  blockedAt DateTime  @default(now()) @map("blocked_at") @db.Timestamptz(6)
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)

  @@map("security_blocked_ips")
}

model FeatureFlag {
  key               String   @id @db.VarChar(100)
  description       String?  @db.Text
  isEnabled         Boolean  @default(false) @map("is_enabled")
  rolloutPercentage Int      @default(100) @map("rollout_percentage")
  targetRolesJson   Json?    @map("target_roles_json") @db.JsonB
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("feature_flags")
}

model UserIdentity {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  provider        IdentityProvider
  providerId      String           @map("provider_id") @db.VarChar(255)
  profileDataJson Json?            @map("profile_data_json") @db.JsonB
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId], name: "uq_identities_provider_id")
  @@index([userId], name: "idx_identities_user")
  @@map("user_identities")
}

model TrustedDevice {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  deviceId          String?  @map("device_id") @db.Uuid
  deviceFingerprint String   @unique @map("device_fingerprint") @db.VarChar(255)
  deviceName        String   @map("device_name") @db.VarChar(100)
  publicKey         String?  @map("public_key") @db.Text
  trustedAt         DateTime @default(now()) @map("trusted_at") @db.Timestamptz(6)
  lastUsedAt        DateTime @default(now()) @map("last_used_at") @db.Timestamptz(6)
  isRevoked         Boolean  @default(false) @map("is_revoked")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRevoked], name: "idx_trusted_user_revoked")
  @@map("trusted_devices")
}

model LoginHistory {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  loginStatus   LoginStatus @map("login_status")
  ipAddress     String?     @map("ip_address") @db.VarChar(45)
  userAgent     String?     @map("user_agent") @db.Text
  location      String?     @db.VarChar(100)
  deviceType    String?     @map("device_type") @db.VarChar(50)
  riskScore     Int         @default(0) @map("risk_score")
  failureReason String?     @map("failure_reason") @db.VarChar(255)
  loginAt       DateTime    @default(now()) @map("login_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loginAt], name: "idx_login_hist_user_date")
  @@index([loginStatus, riskScore], name: "idx_login_hist_status_risk")
  @@map("login_history")
}

// ==============================================================================
// 4. STUDENT PROFILES & GAMIFICATION (Task 18)
// ==============================================================================

model StudentProfile {
  userId                String      @id @map("user_id") @db.Uuid
  dateOfBirth           DateTime?   @map("date_of_birth") @db.Date
  gender                Gender      @default(PREFER_NOT_TO_SAY)
  heightCm              Decimal?    @map("height_cm") @db.Decimal(5, 2)
  weightKg              Decimal?    @map("weight_kg") @db.Decimal(5, 2)
  experienceLevel       CourseLevel @default(BEGINNER) @map("experience_level")
  ayurvedicDosha        DoshaType?  @map("ayurvedic_dosha")
  medicalConditions     String[]    @map("medical_conditions")
  emergencyContactPhone String?     @map("emergency_contact_phone") @db.VarChar(20)
  updatedAt             DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ayurvedicDosha], name: "idx_student_dosha")
  @@index([experienceLevel], name: "idx_student_level")
  @@map("student_profiles")
}

model UserStreak {
  userId            String    @id @map("user_id") @db.Uuid
  currentStreakDays Int       @default(0) @map("current_streak_days")
  longestStreakDays Int       @default(0) @map("longest_streak_days")
  lastActivityDate  DateTime? @map("last_activity_date") @db.Date
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("user_streaks")
}

model GuardianProfile {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentUserId  String           @unique @map("student_user_id") @db.Uuid
  guardianUserId String           @map("guardian_user_id") @db.Uuid
  relationship   RelationshipType @default(PARENT)
  hasFullAccess  Boolean          @default(true) @map("has_full_access")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  student  User @relation("StudentGuardian", fields: [studentUserId], references: [id], onDelete: Cascade)
  guardian User @relation("GuardianToStudent", fields: [guardianUserId], references: [id], onDelete: Cascade)

  @@index([guardianUserId], name: "idx_guardian_user")
  @@map("guardian_profiles")
}

model EmergencyContact {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  name         String           @db.VarChar(255)
  relationship RelationshipType @default(OTHER)
  phone        String           @db.VarChar(20)
  email        String?          @db.VarChar(255)
  isPrimary    Boolean          @default(false) @map("is_primary")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPrimary], name: "idx_emergency_user_primary")
  @@map("emergency_contacts")
}

model MedicalVisibilityControl {
  userId                String   @id @map("user_id") @db.Uuid
  shareWithTeachers     Boolean  @default(false) @map("share_with_teachers")
  shareWithDoctors      Boolean  @default(true) @map("share_with_doctors")
  shareWithNutritionist Boolean  @default(true) @map("share_with_nutritionist")
  allowAiAnalysis       Boolean  @default(true) @map("allow_ai_analysis")
  restrictedFieldsJson  Json?    @default("[]") @map("restricted_fields_json") @db.JsonB
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("medical_visibility_controls")
}

model StudentAchievement {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
