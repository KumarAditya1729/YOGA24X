  preferredClassTimesJson Json?    @default("[]") @map("preferred_class_times_json") @db.JsonB
  preferredLanguagesJson  Json?    @default("[\"en\"]") @map("preferred_languages_json") @db.JsonB
  musicPreferencesJson    Json?    @default("[]") @map("music_preferences_json") @db.JsonB
  notificationPreferences Json?    @default("{}") @map("notification_preferences") @db.JsonB
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_preferences")
}

model StudentAnalyticsSnapshot {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  snapshotDate          DateTime @map("snapshot_date") @db.Date
  learningMetricsJson   Json?    @default("{}") @map("learning_metrics_json") @db.JsonB
  wellnessMetricsJson   Json?    @default("{}") @map("wellness_metrics_json") @db.JsonB
  attendanceMetricsJson Json?    @default("{}") @map("attendance_metrics_json") @db.JsonB
  recommendationsJson   Json?    @default("[]") @map("recommendations_json") @db.JsonB
