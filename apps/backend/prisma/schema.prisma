  providerType    AiProviderType   @map("provider_type")
  name            String           @map("name")
  baseUrl         String?          @map("base_url")
  apiKey          String?          @map("api_key") // Optional, encrypted at rest if provided
  isActive        Boolean          @default(true) @map("is_active")
  priority        Int              @default(100) @map("priority") // Lower is higher priority for fallback
  supportedRoles  AiModelRole[]    @map("supported_roles")
  status          AiProviderStatus @default(ACTIVE) @map("status")
  metadata        Json?            @map("metadata")

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("ai_provider_configs")
}

model PromptTemplate {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  name            String           @unique @map("name")
  version         String           @default("1.0") @map("version")
  content         String           @map("content")
  variables       String[]         @map("variables") // e.g. ["user_name", "goal"]
  specialty       CoachSpecialty?  @map("specialty")
  isActive        Boolean          @default(true) @map("is_active")

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("prompt_templates")
}

model AiConversation {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  userId          String           @map("user_id") @db.Uuid
  specialty       CoachSpecialty   @map("specialty")
  title           String?          @map("title")
  isActive        Boolean          @default(true) @map("is_active")
  summary         String?          @map("summary")

  messages        AiMessage[]
  user            User             @relation("UserConversations", fields: [userId], references: [id])

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([userId])
  @@map("ai_conversations")
}

model AiMessage {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  conversationId  String           @map("conversation_id") @db.Uuid
  role            String           @map("role") // "user", "assistant", "system"
  content         String           @map("content")
  providerUsed    AiProviderType?  @map("provider_used")
  tokensUsed      Int?             @map("tokens_used")
  latencyMs       Int?             @map("latency_ms")

  conversation    AiConversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([conversationId])
  @@map("ai_messages")
}

model AiSafetyAuditLog {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  userId          String?          @map("user_id") @db.Uuid
  eventType       String           @map("event_type") // e.g., PII_BLOCKED, MEDICAL_ADVICE_BLOCKED
  originalInput   String           @map("original_input")
  sanitizedInput  String?          @map("sanitized_input")
  safetyLevel     AiSafetyLevel    @map("safety_level")

  user            User?            @relation("UserSafetyAudits", fields: [userId], references: [id])

  createdAt       DateTime         @default(now()) @map("created_at")

  @@map("ai_safety_audit_logs")
}

model KnowledgeDocument {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  title           String           @map("title")
  sourceType      String           @map("source_type") // e.g., ARTICLE, TRANSCRIPT
  sourceId        String?          @map("source_id")
  isActive        Boolean          @default(true) @map("is_active")
  
  chunks          KnowledgeChunk[]

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  documentId      String           @map("document_id") @db.Uuid
  chunkIndex      Int              @map("chunk_index")
  content         String           @map("content")
  // We avoid vector DB requirement by storing embeddings as JSON arrays for local fast calculation if needed.
  // Or completely relying on text-matching/rules if embeddings are unavailable.
  embedding       Json?            @map("embedding") 

  document        KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([documentId])
  @@map("knowledge_chunks")
}

