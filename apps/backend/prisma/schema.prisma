  user User @relation("UserPermOverrides", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId, tenantId], name: "uq_user_perm_override")
  @@index([userId, tenantId], name: "idx_perm_override_user_tenant")
  @@index([expiresAt], name: "idx_perm_override_expiry")
  @@map("user_permission_overrides")
}

// ── Unified Authorization Audit Log ────────────────────────────────────────────

model AuthorizationAuditLog {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  correlationId  String        @map("correlation_id") @db.Uuid
  userId         String?       @map("user_id") @db.Uuid
  tenantId       String?       @map("tenant_id") @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
