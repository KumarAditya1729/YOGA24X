  aiSession AiCoachSession @relation(fields: [aiSessionId], references: [id], onDelete: Cascade)

  @@index([aiSessionId], name: "idx_pose_logs_session")
  @@map("pose_accuracy_logs")
}

model UserEmbedding {
  userId       String                      @id @map("user_id") @db.Uuid
  // Note: Prisma raw type mapping for pgvector 1536-dimensional vector
  embedding    Unsupported("vector(1536)")
  modelVersion String                      @map("model_version") @db.VarChar(50)
  updatedAt    DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_embeddings")
}

