  totalSessions  Int       @default(0) @map("total_sessions")
  firstSessionAt DateTime? @map("first_session_at") @db.Timestamptz(6)
  lastSessionAt  DateTime? @map("last_session_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacher TeacherProfile       @relation(fields: [teacherUserId], references: [userId], onDelete: Cascade)
  student User                 @relation(fields: [studentUserId], references: [id], onDelete: Cascade)
  notes   TeacherStudentNote[]

  @@unique([teacherUserId, studentUserId], name: "uq_teacher_roster_teacher_student")
  @@index([teacherUserId, isFavorite], name: "idx_teacher_roster_fav")
  @@map("teacher_student_rosters")
}

model TeacherStudentNote {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rosterId        String   @map("roster_id") @db.Uuid
  noteText        String   @map("note_text") @db.Text
  isPrivate       Boolean  @default(true) @map("is_private")
  containsMedical Boolean  @default(false) @map("contains_medical")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  roster TeacherStudentRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@index([rosterId], name: "idx_teacher_student_note_roster")
  @@map("teacher_student_notes")
}

// ── Teacher Earnings & Payouts ─────────────────────────────────────────────────

model TeacherPayoutRequest {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  amountCents    Int          @map("amount_cents")
  currency       String       @default("USD") @db.VarChar(3)
  status         PayoutStatus @default(PENDING)
  bankAccountId  String?      @map("bank_account_id") @db.VarChar(100)
  transactionRef String?      @map("transaction_ref") @db.VarChar(255)
  requestedAt    DateTime     @default(now()) @map("requested_at") @db.Timestamptz(6)
  processedAt    DateTime?    @map("processed_at") @db.Timestamptz(6)

  teacher TeacherProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, status], name: "idx_teacher_payout_user_status")
  @@map("teacher_payout_requests")
}

// ==============================================================================
// 7. LMS EXTENSIONS: EVENTS, PUBLISHING & STUDENT INTERACTIVITY (Prompt 6.3)
// ==============================================================================

model LearningEvent {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId         String?           @map("course_id") @db.Uuid
  instructorId     String            @map("instructor_id") @db.Uuid
  title            String            @db.VarChar(255)
  eventType        LearningEventType @map("event_type")
  description      String            @db.Text
  capacity         Int               @default(0)
  priceCents       Int               @default(0) @map("price_cents")
  meetingProvider  String?           @map("meeting_provider") @db.VarChar(50)
  meetingUrl       String?           @map("meeting_url") @db.Text
  scheduledStartAt DateTime          @map("scheduled_start_at") @db.Timestamptz(6)
  scheduledEndAt   DateTime          @map("scheduled_end_at") @db.Timestamptz(6)
  agenda           Json?
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  course        Course?             @relation(fields: [courseId], references: [id], onDelete: SetNull)
  instructor    InstructorProfile   @relation(fields: [instructorId], references: [userId], onDelete: Restrict)
  registrations EventRegistration[]
  WaitlistEntry WaitlistEntry[]

  @@index([instructorId], name: "idx_learning_events_instructor")
  @@map("learning_events")
}

model EventRegistration {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId       String   @map("event_id") @db.Uuid
  studentUserId String   @map("student_user_id") @db.Uuid
  registeredAt  DateTime @default(now()) @map("registered_at") @db.Timestamptz(6)
  hasAttended   Boolean  @default(false) @map("has_attended")

  event   LearningEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student User          @relation(fields: [studentUserId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentUserId], name: "uq_event_registration_student")
  @@map("event_registrations")
}

model TeacherPublication {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instructorId    String          @map("instructor_id") @db.Uuid
  title           String          @db.VarChar(255)
  publicationType PublicationType @map("publication_type")
  contentBody     String?         @map("content_body") @db.Text
  assetUrl        String?         @map("asset_url") @db.Text
  isPublished     Boolean         @default(false) @map("is_published")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  instructor InstructorProfile @relation(fields: [instructorId], references: [userId], onDelete: Restrict)

  @@index([instructorId], name: "idx_publications_instructor")
  @@map("teacher_publications")
}

model LearningBookmark {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentUserId String   @map("student_user_id") @db.Uuid
  courseId      String   @map("course_id") @db.Uuid
  bookmarkedAt  DateTime @default(now()) @map("bookmarked_at") @db.Timestamptz(6)

  student User   @relation(fields: [studentUserId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentUserId, courseId], name: "uq_learning_bookmark")
  @@map("learning_bookmarks")
}

model LearningNote {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentUserId  String   @map("student_user_id") @db.Uuid
  lessonId       String   @map("lesson_id") @db.Uuid
  content        String   @db.Text
  videoTimestamp Int?     @map("video_timestamp")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
