// ── Reviews ────────────────────────────────────────────────────────────────────

model TeacherReview {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherUserId       String   @map("teacher_user_id") @db.Uuid
  studentUserId       String   @map("student_user_id") @db.Uuid
  bookingId           String?  @map("booking_id") @db.Uuid
  rating              Int
  reviewText          String?  @map("review_text") @db.Text
  communicationRating Int?     @map("communication_rating")
  knowledgeRating     Int?     @map("knowledge_rating")
  punctualityRating   Int?     @map("punctuality_rating")
  isVerifiedBooking   Boolean  @default(false) @map("is_verified_booking")
  isHidden            Boolean  @default(false) @map("is_hidden")
