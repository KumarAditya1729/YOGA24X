model ProductCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  products Product[]

  @@map("product_categories")
}

model Product {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId     String   @map("category_id") @db.Uuid
  name           String   @db.VarChar(255)
  slug           String   @unique @db.VarChar(255)
  description    String?  @db.Text
  basePriceCents Int      @map("base_price_cents")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  category ProductCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants ProductVariant[]

  @@map("products")
}

model ProductVariant {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId          String   @map("product_id") @db.Uuid
  sku                String   @unique @db.VarChar(100)
  variantName        String   @map("variant_name") @db.VarChar(150)
  priceOverrideCents Int?     @map("price_override_cents")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem?
  orderItems    OrderItem[]

  @@map("product_variants")
}

model InventoryItem {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId        String   @unique @map("variant_id") @db.Uuid
  quantityOnHand   Int      @default(0) @map("quantity_on_hand")
  quantityReserved Int      @default(0) @map("quantity_reserved")
  reorderThreshold Int      @default(10) @map("reorder_threshold")
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("inventory_items")
}

model Order {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String      @map("user_id") @db.Uuid
  orderNumber      String      @unique @map("order_number") @db.VarChar(50)
  totalAmountCents Int         @map("total_amount_cents")
  status           OrderStatus @default(PENDING)
  shippingAddress  Json        @map("shipping_address") @db.JsonB
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  user       User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@index([userId, status], name: "idx_orders_user_status")
  @@map("orders")
}

model OrderItem {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String @map("order_id") @db.Uuid
  variantId      String @map("variant_id") @db.Uuid
  quantity       Int
  unitPriceCents Int    @map("unit_price_cents")

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

