  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, achievementType], name: "idx_achievement_user_type")
  @@map("student_achievements")
}

model StudentPreference {
  userId                  String   @id @map("user_id") @db.Uuid
  preferredTeacherIdsJson Json?    @default("[]") @map("preferred_teacher_ids_json") @db.JsonB
