  @@unique([userId, snapshotDate], name: "uq_analytics_user_date")
  @@index([userId, snapshotDate], name: "idx_analytics_user_date")
  @@map("student_analytics_snapshots")
}

// ==============================================================================
// 5. INSTRUCTORS & DOCTORS (Tasks 17, 23)
// ==============================================================================

model InstructorProfile {
  userId               String   @id @map("user_id") @db.Uuid
  bio                  String   @db.Text
  yearsExperience      Int      @default(0) @map("years_experience")
  specializations      String[]
  hourlyRateCents      Int      @default(0) @map("hourly_rate_cents")
  commissionPercentage Decimal  @default(20.00) @map("commission_percentage") @db.Decimal(5, 2)
  averageRating        Decimal  @default(0.00) @map("average_rating") @db.Decimal(3, 2)
  totalReviews         Int      @default(0) @map("total_reviews")
  isVerified           Boolean  @default(false) @map("is_verified")
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses            Course[]
  classSchedules     ClassSchedule[]
  verifications      InstructorVerification[]
  ratings            InstructorRating[]
  LearningEvent      LearningEvent[]
  TeacherPublication TeacherPublication[]
  CancellationPolicy CancellationPolicy[]

  @@index([averageRating], name: "idx_instructor_rating")
  @@map("instructor_profiles")
}

model InstructorVerification {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instructorId String    @map("instructor_id") @db.Uuid
  documentType String    @map("document_type") @db.VarChar(50)
  documentUrl  String    @map("document_url") @db.Text
  status       String    @default("PENDING") @db.VarChar(20)
  reviewedBy   String?   @map("reviewed_by") @db.Uuid
  remarks      String?   @db.Text
  submittedAt  DateTime  @default(now()) @map("submitted_at") @db.Timestamptz(6)
  reviewedAt   DateTime? @map("reviewed_at") @db.Timestamptz(6)

  instructor InstructorProfile @relation(fields: [instructorId], references: [userId], onDelete: Cascade)

  @@map("instructor_verifications")
}

model InstructorRating {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instructorId String   @map("instructor_id") @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  rating       Int
  reviewText   String?  @map("review_text") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  instructor InstructorProfile @relation(fields: [instructorId], references: [userId], onDelete: Cascade)

  @@unique([instructorId, studentId], name: "uq_rating_instructor_student")
  @@map("instructor_ratings")
}

model DoctorProfile {
  userId                    String   @id @map("user_id") @db.Uuid
  medicalRegistrationNumber String   @unique @map("medical_registration_number") @db.VarChar(100)
  qualification             String   @db.VarChar(255)
  consultationFeeCents      Int      @default(0) @map("consultation_fee_cents")
  averageRating             Decimal  @default(0.00) @map("average_rating") @db.Decimal(3, 2)
  isVerified                Boolean  @default(false) @map("is_verified")
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarSlots CalendarSlot[]

  @@map("doctor_profiles")
}

// ==============================================================================
// 6. LMS: COURSES, LESSONS & QUIZZES (Tasks 15, 16)
// ==============================================================================

model Course {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instructorId         String           @map("instructor_id") @db.Uuid
  tenantId             String?          @map("tenant_id") @db.Uuid
  title                String           @db.VarChar(255)
  slug                 String           @unique @db.VarChar(255)
  description          String           @db.Text
  thumbnailUrl         String?          @map("thumbnail_url") @db.Text
  previewVideoUrl      String?          @map("preview_video_url") @db.Text
  level                CourseLevel
  priceCents           Int              @default(0) @map("price_cents")
  isPublished          Boolean          @default(false) @map("is_published")
  visibility           CourseVisibility @default(DRAFT)
  language             String?          @db.VarChar(50)
  version              String           @default("1.0") @db.VarChar(50)
  scheduledPublishAt   DateTime?        @map("scheduled_publish_at") @db.Timestamptz(6)
  learningOutcomes     String[]         @map("learning_outcomes")
  prerequisites        String[]
  tags                 String[]
  aiMetadata           Json?            @map("ai_metadata")
  totalDurationSeconds Int              @default(0) @map("total_duration_seconds")
  isDeleted            Boolean          @default(false) @map("is_deleted")
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  instructor        InstructorProfile  @relation(fields: [instructorId], references: [userId], onDelete: Restrict)
  modules           CourseModule[]
  enrollments       CourseEnrollment[]
  certificates      Certificate[]
  learningEvents    LearningEvent[]
  learningBookmarks LearningBookmark[]

  @@index([instructorId], name: "idx_courses_instructor")
  @@index([level, isPublished], name: "idx_courses_level_published")
  @@map("courses")
}

model CourseModule {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId      String   @map("course_id") @db.Uuid
  title         String   @db.VarChar(255)
  sequenceOrder Int      @map("sequence_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, sequenceOrder], name: "uq_module_course_order")
  @@map("course_modules")
}

model Lesson {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId              String     @map("module_id") @db.Uuid
  title                 String     @db.VarChar(255)
  lessonType            LessonType @default(VIDEO) @map("lesson_type")
  isDependencyRequired  Boolean    @default(false) @map("is_dependency_required")
  prerequisiteLessonIds String[]   @map("prerequisite_lesson_ids")
  aiTranscriptHash      String?    @map("ai_transcript_hash") @db.VarChar(255)
  videoAssetId          String?    @map("video_asset_id") @db.Uuid
  durationSeconds       Int        @default(0) @map("duration_seconds")
  sequenceOrder         Int        @map("sequence_order")
  isPreviewFree         Boolean    @default(false) @map("is_preview_free")
  createdAt             DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  module             CourseModule        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  videoAsset         MediaAsset?         @relation(fields: [videoAssetId], references: [id], onDelete: SetNull)
  progressRecords    LessonProgress[]
  quizzes            Quiz[]
  aiSessions         AiCoachSession[]
  learningNotes      LearningNote[]
  learningHighlights LearningHighlight[]

  @@index([moduleId, sequenceOrder], name: "idx_lessons_module_order")
  @@map("lessons")
}

model CourseEnrollment {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  courseId           String    @map("course_id") @db.Uuid
  enrolledAt         DateTime  @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  completedAt        DateTime? @map("completed_at") @db.Timestamptz(6)
  progressPercentage Decimal   @default(0.00) @map("progress_percentage") @db.Decimal(5, 2)

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgresses LessonProgress[]
  userCertificate  UserCertificate?

  @@unique([userId, courseId], name: "uq_enrollment_user_course")
  @@index([userId], name: "idx_enrollments_user")
  @@map("course_enrollments")
}

model LessonProgress {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId      String    @map("enrollment_id") @db.Uuid
  lessonId          String    @map("lesson_id") @db.Uuid
  lastWatchedSecond Int       @default(0) @map("last_watched_second")
  isCompleted       Boolean   @default(false) @map("is_completed")
  completedAt       DateTime? @map("completed_at") @db.Timestamptz(6)

  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId], name: "uq_progress_enrollment_lesson")
  @@map("lesson_progress")
}

model Quiz {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId     String   @map("lesson_id") @db.Uuid
  title        String   @db.VarChar(255)
  passingScore Int      @default(70) @map("passing_score")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quizId        String @map("quiz_id") @db.Uuid
  questionText  String @map("question_text") @db.Text
  optionsJson   Json   @map("options_json") @db.JsonB
  correctOption Int    @map("correct_option")
  sequenceOrder Int    @map("sequence_order")

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model Certificate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  title       String   @db.VarChar(255)
  templateUrl String?  @map("template_url") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  course           Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userCertificates UserCertificate[]

  @@map("certificates")
}

model UserCertificate {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  certificateId String   @map("certificate_id") @db.Uuid
  enrollmentId  String   @unique @map("enrollment_id") @db.Uuid
  certificateNo String   @unique @map("certificate_no") @db.VarChar(100)
  issuedAt      DateTime @default(now()) @map("issued_at") @db.Timestamptz(6)
  pdfUrl        String?  @map("pdf_url") @db.Text

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificate Certificate      @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  enrollment  CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  blockchainHash String?   @map("blockchain_hash") @db.VarChar(255)
  expiryDate     DateTime? @map("expiry_date") @db.Timestamptz(6)

  @@map("user_certificates")
}

// ==============================================================================
// 7. LIVE CLASSES, CALENDAR & BOOKINGS (Tasks 14, 24, 25)
// ==============================================================================

model ClassSchedule {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instructorId    String   @map("instructor_id") @db.Uuid
  title           String   @db.VarChar(255)
  description     String?  @db.Text
  maxParticipants Int      @default(50) @map("max_participants")
  priceCents      Int      @default(0) @map("price_cents")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  instructor    InstructorProfile @relation(fields: [instructorId], references: [userId], onDelete: Restrict)
  calendarSlots CalendarSlot[]

  @@map("class_schedules")
}

model CalendarSlot {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId  String?  @map("schedule_id") @db.Uuid
  doctorId    String?  @map("doctor_id") @db.Uuid
  startTime   DateTime @map("start_time") @db.Timestamptz(6)
  endTime     DateTime @map("end_time") @db.Timestamptz(6)
  isBookedOut Boolean  @default(false) @map("is_booked_out")

  schedule ClassSchedule? @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  doctor   DoctorProfile? @relation(fields: [doctorId], references: [userId], onDelete: Cascade)
  bookings Booking[]

  @@index([scheduleId, startTime], name: "idx_slot_schedule_time")
  @@map("calendar_slots")
}

model Booking {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String        @map("user_id") @db.Uuid
  slotId               String        @map("slot_id") @db.Uuid
  status               BookingStatus @default(CONFIRMED)
  bookingReference     String        @unique @map("booking_reference") @db.VarChar(50)
  paymentTransactionId String?       @map("payment_transaction_id") @db.Uuid
  bookedAt             DateTime      @default(now()) @map("booked_at") @db.Timestamptz(6)
  cancelledAt          DateTime?     @map("cancelled_at") @db.Timestamptz(6)

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  slot CalendarSlot @relation(fields: [slotId], references: [id], onDelete: Restrict)

  @@index([userId, status], name: "idx_bookings_user_status")
  @@index([slotId], name: "idx_bookings_slot")
  @@map("bookings")
}

// ==============================================================================
// 8. MONETIZATION, WALLET & PAYMENTS (Task 13)
// ==============================================================================

model Wallet {
  userId       String   @id @map("user_id") @db.Uuid
  balanceCents BigInt   @default(0) @map("balance_cents")
  currency     String   @default("INR") @db.VarChar(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletId        String   @map("wallet_id") @db.Uuid
  amountCents     BigInt   @map("amount_cents")
  transactionType String   @map("transaction_type") @db.VarChar(30)
  referenceId     String?  @map("reference_id") @db.Uuid
  description     String?  @db.VarChar(255)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  wallet Wallet @relation(fields: [walletId], references: [userId], onDelete: Cascade)

  @@index([walletId, createdAt], name: "idx_wallet_trans_wallet_date")
  @@map("wallet_transactions")
}

model SubscriptionPlan {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String  @unique @db.VarChar(100)
  razorpayPlanId  String  @unique @map("razorpay_plan_id") @db.VarChar(100)
  priceCents      Int     @map("price_cents")
  billingInterval String  @map("billing_interval") @db.VarChar(20)
  featuresJson    Json?   @map("features_json") @db.JsonB
  isActive        Boolean @default(true) @map("is_active")

  userSubscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String   @map("user_id") @db.Uuid
  planId                 String   @map("plan_id") @db.Uuid
  razorpaySubscriptionId String   @unique @map("razorpay_subscription_id") @db.VarChar(100)
  status                 String   @db.VarChar(30)
  currentPeriodStart     DateTime @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd       DateTime @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd      Boolean  @default(false) @map("cancel_at_period_end")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId, status], name: "idx_user_subs_user_status")
  @@map("user_subscriptions")
}

model PaymentTransaction {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  razorpayOrderId   String        @unique @map("razorpay_order_id") @db.VarChar(100)
  razorpayPaymentId String?       @unique @map("razorpay_payment_id") @db.VarChar(100)
  razorpaySignature String?       @map("razorpay_signature") @db.VarChar(255)
  amountCents       Int           @map("amount_cents")
  currency          String        @default("INR") @db.VarChar(3)
  status            PaymentStatus
  paymentMethod     String?       @map("payment_method") @db.VarChar(50)
  errorCode         String?       @map("error_code") @db.VarChar(100)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  invoice Invoice?

  @@index([razorpayOrderId], name: "idx_pay_rzp_order")
  @@index([userId, status], name: "idx_pay_user_status")
  @@map("payment_transactions")
}

model Invoice {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentTransactionId String   @unique @map("payment_transaction_id") @db.Uuid
  invoiceNumber        String   @unique @map("invoice_number") @db.VarChar(100)
  pdfUrl               String?  @map("pdf_url") @db.Text
  issuedAt             DateTime @default(now()) @map("issued_at") @db.Timestamptz(6)

  transaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// ==============================================================================
// 8b. ENTERPRISE COMMERCE PLATFORM (Prompt 10)
// ==============================================================================

model MembershipPlan {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String         @unique @db.VarChar(100)
  membershipType  MembershipType @map("membership_type")
  priceCents      Int            @map("price_cents")
  durationDays    Int            @map("duration_days")
  maxFreezeDays   Int            @default(30) @map("max_freeze_days")
  featuresJson    Json?          @map("features_json") @db.JsonB
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  memberships Membership[]

  @@map("membership_plans")
}

model Membership {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  planId          String           @map("plan_id") @db.Uuid
  status          MembershipStatus @default(PENDING)
  startDate       DateTime         @map("start_date") @db.Timestamptz(6)
  endDate         DateTime         @map("end_date") @db.Timestamptz(6)
  freezeStartDate DateTime?        @map("freeze_start_date") @db.Timestamptz(6)
  freezeEndDate   DateTime?        @map("freeze_end_date") @db.Timestamptz(6)
  autoRenew       Boolean          @default(true) @map("auto_renew")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan MembershipPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId, status], name: "idx_membership_user_status")
  @@index([endDate], name: "idx_membership_end_date")
  @@map("memberships")
}

model Coupon {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String     @unique @db.VarChar(50)
  couponType          CouponType @map("coupon_type")
  discountPercent     Int?       @map("discount_percent")
  discountCents       Int?       @map("discount_cents")
  maxUsageCount       Int?       @map("max_usage_count")
  usageCount          Int        @default(0) @map("usage_count")
  perUserLimit        Int        @default(1) @map("per_user_limit")
  minOrderCents       Int?       @map("min_order_cents")
  maxDiscountCents    Int?       @map("max_discount_cents")
  applicablePlanIds   Json?      @map("applicable_plan_ids") @db.JsonB
  isActive            Boolean    @default(true) @map("is_active")
  startsAt            DateTime?  @map("starts_at") @db.Timestamptz(6)
  expiresAt           DateTime?  @map("expires_at") @db.Timestamptz(6)
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  redemptions CouponRedemption[]

  @@index([code], name: "idx_coupon_code")
  @@index([isActive, expiresAt], name: "idx_coupon_active")
  @@map("coupons")
}

model CouponRedemption {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couponId      String   @map("coupon_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  orderId       String?  @map("order_id") @db.Uuid
  discountCents Int      @map("discount_cents")
  redeemedAt    DateTime @default(now()) @map("redeemed_at") @db.Timestamptz(6)

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId, orderId], name: "uniq_coupon_user_order")
  @@map("coupon_redemptions")
}

model GiftCard {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String        @unique @db.VarChar(50)
  amountCents  Int           @map("amount_cents")
  currency     String        @default("INR") @db.VarChar(3)
  status       GiftCardStatus @default(ACTIVE)
  issuedToId   String?       @map("issued_to_id") @db.Uuid
  purchasedById String?      @map("purchased_by_id") @db.Uuid
  expiresAt    DateTime?     @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  issuedTo   User?               @relation("GiftCardIssuedTo", fields: [issuedToId], references: [id], onDelete: SetNull)
  purchasedBy User?              @relation("GiftCardPurchasedBy", fields: [purchasedById], references: [id], onDelete: SetNull)
  redemptions GiftCardRedemption[]

  @@map("gift_cards")
}

model GiftCardRedemption {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  giftCardId  String   @map("gift_card_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  amountCents Int      @map("amount_cents")
  redeemedAt  DateTime @default(now()) @map("redeemed_at") @db.Timestamptz(6)

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Restrict)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gift_card_redemptions")
}

model Refund {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentTransactionId String      @map("payment_transaction_id") @db.Uuid
  userId              String       @map("user_id") @db.Uuid
  amountCents         Int          @map("amount_cents")
  reason              RefundReason
  status              RefundStatus @default(PENDING)
  refundToWallet      Boolean      @default(false) @map("refund_to_wallet")
  gatewayRefundId     String?      @unique @map("gateway_refund_id") @db.VarChar(100)
  approvedById        String?      @map("approved_by_id") @db.Uuid
  adminNote           String?      @map("admin_note") @db.Text
  requestedAt         DateTime     @default(now()) @map("requested_at") @db.Timestamptz(6)
  processedAt         DateTime?    @map("processed_at") @db.Timestamptz(6)

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy User?              @relation("RefundApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([userId, status], name: "idx_refund_user_status")
  @@map("refunds")
}

model RevenueShare {
  id                    String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentTransactionId  String           @map("payment_transaction_id") @db.Uuid
  recipientId           String           @map("recipient_id") @db.Uuid
  shareType             RevenueShareType @map("share_type")
  sharePercent          Float            @map("share_percent")
  amountCents           Int              @map("amount_cents")
  currency              String           @default("INR") @db.VarChar(3)
  settlementBatchId     String?          @map("settlement_batch_id") @db.Uuid
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  recipient User              @relation("RevenueShareRecipient", fields: [recipientId], references: [id], onDelete: Restrict)
  batch     SettlementBatch?  @relation(fields: [settlementBatchId], references: [id], onDelete: SetNull)

  @@index([recipientId], name: "idx_revshare_recipient")
  @@index([settlementBatchId], name: "idx_revshare_batch")
  @@map("revenue_shares")
}

model SettlementBatch {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipientId   String           @map("recipient_id") @db.Uuid
  status        SettlementStatus @default(PENDING)
  totalCents    Int              @map("total_cents")
  currency      String           @default("INR") @db.VarChar(3)
  settledAt     DateTime?        @map("settled_at") @db.Timestamptz(6)
  gatewayRef    String?          @map("gateway_ref") @db.VarChar(100)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  recipient     User           @relation("SettlementRecipient", fields: [recipientId], references: [id], onDelete: Restrict)
  revenueShares RevenueShare[]

  @@index([recipientId, status], name: "idx_settlement_recipient_status")
  @@map("settlement_batches")
}

model PricingRule {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String          @db.VarChar(100)
  ruleType        PricingRuleType @map("rule_type")
  discountPercent Int?            @map("discount_percent")
  discountCents   Int?            @map("discount_cents")
  conditions      Json?           @db.JsonB
  priority        Int             @default(0)
  startsAt        DateTime?       @map("starts_at") @db.Timestamptz(6)
  expiresAt       DateTime?       @map("expires_at") @db.Timestamptz(6)
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([ruleType, isActive], name: "idx_pricing_rule_type_active")
  @@map("pricing_rules")
}

model IdempotencyKey {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key          String   @unique @db.VarChar(255)
  userId       String   @map("user_id") @db.Uuid
  responseBody Json?    @map("response_body") @db.JsonB
  statusCode   Int      @map("status_code")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)

  @@index([key], name: "idx_idempotency_key")
  @@index([expiresAt], name: "idx_idempotency_expires")
  @@map("idempotency_keys")
}

model PaymentWebhookEvent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gateway       String   @db.VarChar(30)
  eventId       String   @unique @map("event_id") @db.VarChar(100)
  eventType     String   @map("event_type") @db.VarChar(100)
  payload       Json     @db.JsonB
  signature     String?  @db.VarChar(512)
  processed     Boolean  @default(false)
  processedAt   DateTime? @map("processed_at") @db.Timestamptz(6)
  receivedAt    DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)

  @@index([eventId], name: "idx_webhook_event_id")
  @@index([processed], name: "idx_webhook_processed")
  @@map("payment_webhook_events")
}

