{
  "name": "yoga24x-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Yoga24X AI-Powered Yoga & Wellness Super App Monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,css}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "prettier": "^3.3.2",
    "turbo": "^2.0.4",
    "typescript": "^5.5.2"
  },
  "packageManager": "pnpm@9.4.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
